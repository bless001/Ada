# ---------------------------------------------------------------------------
# Versions
# ---------------------------------------------------------------------------
OPENPROJECT_VERSION=17
WEAVIATE_VERSION=1.38.2

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=coding_agent
POSTGRES_PASSWORD=TN9OFGxsgTywodFv1fqP_XRNNTyQfvVkAwGxo2ZIrYE
POSTGRES_APP_DB=coding_agent
POSTGRES_OPENPROJECT_DB=openproject
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_QUEUE=pm_webhook_events

# ---------------------------------------------------------------------------
# OpenProject
# ---------------------------------------------------------------------------
OPENPROJECT_PORT=8081
OPENPROJECT_HOST_NAME=localhost:8081
OPENPROJECT_SECRET_KEY_BASE=0928abcee0d14805247cb383f4904c77c859cb4a9c63a418ca29d92121a55e5d98fdffc528c0799ceeabfaf1cad78b9a368e61612d78f33c0c7fdbfe2d47c625
OPENPROJECT_API_HOST_HEADER=localhost:8081

# ---------------------------------------------------------------------------
# Auto-created OpenProject bot user
# MVP: admin=true gives the bot broad control to create and maintain projects.
# ---------------------------------------------------------------------------
OP_AGENT_LOGIN=coding-agent-bot
OP_AGENT_EMAIL=coding-agent-bot@example.local
OP_AGENT_FIRSTNAME=Coding
OP_AGENT_LASTNAME=Agent
OP_AGENT_ADMIN=true

# ---------------------------------------------------------------------------
# Auto-created OpenProject webhook
# Use the Docker service name, not localhost, because OpenProject calls this
# from inside the Docker network.
# ---------------------------------------------------------------------------
OP_AGENT_WEBHOOK_NAME=Coding Agent Webhook
OP_AGENT_WEBHOOK_URL=http://agent-webhook:8090/webhooks/openproject
OP_AGENT_WEBHOOK_DESCRIPTION=Triggers the coding agent when OpenProject work packages or comments change.
OP_AGENT_WEBHOOK_ALL_PROJECTS=true
OP_AGENT_WEBHOOK_EVENTS=work_package:created,work_package:updated,work_package_comment:comment,work_package_comment:internal_comment

# Create a starter project automatically for first testing.
OP_CREATE_STARTER_PROJECT=true
OP_STARTER_PROJECT_IDENTIFIER=coding-agent-demo
OP_STARTER_PROJECT_NAME=Coding Agent Demo

# ---------------------------------------------------------------------------
# Agent webhook receiver
# ---------------------------------------------------------------------------
AGENT_WEBHOOK_PORT=8090

# For first local run keep this false.
# After you verify OpenProject's signature header in your version, set true.
WEBHOOK_REQUIRE_SIGNATURE=false
WEBHOOK_SIGNATURE_SECRET=c95c64adb85c80280936248a308ef0935afbeadae586fbe8a4be0f3dc42ee814
WEBHOOK_SIGNATURE_HEADER=X-Op-Signature

# The agent only starts implementation when work package status matches this.
AGENT_TRIGGER_STATUS_NAMES=In Development,Agent Development

# ---------------------------------------------------------------------------
# Neo4j
# ---------------------------------------------------------------------------
NEO4J_USER=neo4j
NEO4J_PASSWORD=STwbdqwa5c7dfS3NAusKf47WqOohUX25quqaEYgxNDA
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_PAGECACHE_SIZE=1G
